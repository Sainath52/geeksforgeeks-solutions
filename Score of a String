    public int scoreOfString(String s) {
        int score = 0;
        byte[] bytes = s.getBytes();
        for(int i = 1;i<bytes.length;i++)
        {
            int diff = Math.abs(bytes[i] - bytes[i-1]);
            score+=diff;
        }
        return score;
    }
